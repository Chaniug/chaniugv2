---
// 极简背景层：纸感径向微光 + 极淡颗粒纹理
// 无粒子 / 无极光 / 无光球，纯静态，零运行时开销
---
<div id="bg-field" aria-hidden="true">
  <div class="bg-grain"></div>
</div>

<style>
  #bg-field {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(
      125% 80% at 50% -12%,
      var(--accent-soft),
      transparent 58%
    );
  }
  .bg-grain {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n' x='0' y='0'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 180px 180px;
  }
  html[data-theme='dark'] #bg-field {
    background: radial-gradient(
      125% 80% at 50% -12%,
      rgba(111, 155, 255, 0.07),
      transparent 58%
    );
  }
  html[data-theme='dark'] .bg-grain {
    opacity: 0.04;
  }
</style>
