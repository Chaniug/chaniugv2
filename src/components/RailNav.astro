---
// 横向滑轨交互：箭头翻页 / 拖动浏览 / 边缘渐隐 / 进度条（phase C 横向展示）
// 纯全局脚本，渲染层不输出可见 DOM
---
<script>
  type Rail = {
    wrap: HTMLElement;
    rail: HTMLElement;
    prev: HTMLButtonElement | null;
    next: HTMLButtonElement | null;
    bar: HTMLElement | null;
    raf: number;
  };

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const rails: Rail[] = [];

  function update(r: Rail) {
    const max = r.rail.scrollWidth - r.rail.clientWidth;
    const x = r.rail.scrollLeft;
    const atStart = x <= 2;
    const atEnd = x >= max - 2;
    r.wrap.classList.toggle('at-start', atStart);
    r.wrap.classList.toggle('at-end', atEnd);
    if (r.bar) r.bar.style.width = max > 0 ? `${Math.min(100, (x / max) * 100)}%` : '0%';
    if (r.prev) r.prev.disabled = atStart;
    if (r.next) r.next.disabled = atEnd;
  }

  function schedule(r: Rail) {
    cancelAnimationFrame(r.raf);
    r.raf = requestAnimationFrame(() => update(r));
  }

  function initRail(wrap: HTMLElement): Rail {
    const rail = wrap.querySelector<HTMLElement>('.h-rail')!;
    const prev = wrap.querySelector<HTMLButtonElement>('.rail-prev');
    const next = wrap.querySelector<HTMLButtonElement>('.rail-next');
    const bar = wrap.querySelector<HTMLElement>('.rail-progress > i');

    const step = () => Math.max(rail.clientWidth * 0.8, 240);

    prev?.addEventListener('click', () => rail.scrollBy({ left: -step(), behavior: reduced ? 'auto' : 'smooth' }));
    next?.addEventListener('click', () => rail.scrollBy({ left: step(), behavior: reduced ? 'auto' : 'smooth' }));

    rail.addEventListener('scroll', () => schedule(r as Rail), { passive: true });
    window.addEventListener('resize', () => schedule(r as Rail), { passive: true });

    // 拖动浏览（桌面）：在卡片/链接上按下并移动超过阈值则视为拖动，抑制随后的点击
    let down = false;
    let startX = 0;
    let startLeft = 0;
    let moved = 0;
    rail.addEventListener('pointerdown', (e) => {
      if (e.pointerType === 'touch') return; // 触摸交给原生滑动
      down = true;
      moved = 0;
      startX = e.clientX;
      startLeft = rail.scrollLeft;
    });
    rail.addEventListener('pointermove', (e) => {
      if (!down) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 4) {
        moved = dx;
        rail.classList.add('is-dragging');
        rail.scrollLeft = startLeft - dx;
      }
    });
    const end = () => {
      if (!down) return;
      down = false;
      rail.classList.remove('is-dragging');
      if (Math.abs(moved) > 6) {
        // 阻止拖动误触链接
        const stop = (ev: Event) => {
          ev.preventDefault();
          ev.stopPropagation();
          rail.removeEventListener('click', stop, true);
        };
        rail.addEventListener('click', stop, true);
        setTimeout(() => rail.removeEventListener('click', stop, true), 0);
      }
    };
    rail.addEventListener('pointerup', end);
    rail.addEventListener('pointercancel', end);
    rail.addEventListener('pointerleave', end);

    const r: Rail = { wrap, rail, prev, next, bar, raf: 0 };
    update(r);
    return r;
  }

  function boot() {
    document.querySelectorAll<HTMLElement>('[data-rail]').forEach((w) => {
      if (w.dataset.railReady) return;
      w.dataset.railReady = '1';
      rails.push(initRail(w));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
