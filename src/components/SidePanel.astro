---
import { site } from '../data/site';
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL;

const socials = [
  { key: 'x', label: 'X (Twitter)', href: 'https://x.com/valkjin' },
  { key: 'tg', label: 'Telegram', href: 'https://t.me/valkjin' },
  { key: 'github', label: 'GitHub', href: 'https://github.com/Chaniug' },
  { key: 'email', label: 'Email', href: 'mailto:you@example.com' },
];

const socialIcons: Record<string, string> = {
  x: '<svg viewBox="0 0 32 32" fill="none"><path d="M6 6l8.8 12L6 28h2l7.7-9 6.3 9H28l-9.3-12.6L25.6 6h-2l-7 8.4L10.4 6H6z" fill="currentColor"/></svg>',
  tg: '<svg viewBox="0 0 32 32" fill="none"><path d="M5 15l8 3.2 3.2 8L26 6 5 15z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>',
  github:
    '<svg viewBox="0 0 32 32" fill="none"><path d="M12 27c-5 1.2-5-2.5-7.5-3m14.5 11v-5.4c0-1.5-.5-2.7-1.3-3.5 4.5-.5 9.3-2.3 9.3-10 0-2.2-.8-4-2-5.5.2-.5.8-2.6-.3-5.3 0 0-1.7-.5-5.5 2a19 19 0 00-10 0c-3.8-2.5-5.5-2-5.5-2-1.1 2.7-.5 4.8-.3 5.3a8 8 0 00-2 5.5c0 7.7 4.8 9.5 9.3 10-.7.8-1.3 2-1.3 3.5V32" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  email:
    '<svg viewBox="0 0 32 32" fill="none"><rect x="4" y="7" width="24" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M4 10l12 9 12-9" stroke="currentColor" stroke-width="1.5"/></svg>',
};
---
<aside class="side-panel" aria-label="身份与导航">
  <div class="sp-top">
    <div class="sp-brand">
      <img
        class="sp-avatar"
        src={`${base}img/avatar.webp`}
        alt={site.name}
        width="50"
        height="50"
      />
      <div class="sp-brand-text">
        <span class="sp-name">{site.name}</span>
        <span class="sp-role">{site.role}</span>
      </div>
    </div>
    <p class="sp-bio">{site.description}</p>
    <div class="sp-status">
      <div class="sp-status-row">
        <span class="sp-dot" aria-hidden="true"></span>
        <span>在线 · {site.location}</span>
      </div>
    </div>
  </div>

  <nav class="sp-nav" aria-label="章节导航">
    {
      site.nav.map((n, i) => (
        <a class="sp-nav-link" href={`#${n.id}`} data-nav={n.id}>
          <span class="sp-nav-idx">{String(i + 1).padStart(2, '0')}</span>
          <span>{n.label}</span>
        </a>
      ))
    }
  </nav>

  <div class="sp-bottom">
    <div class="sp-social">
      {
        socials.map((s) => (
          <a
            class="sp-social-link"
            href={s.href}
            target="_blank"
            rel="noopener"
            aria-label={s.label}
            set:html={socialIcons[s.key]}
          />
        ))
      }
    </div>
    <div class="sp-foot-row">
      <span class="sp-foot">© {new Date().getFullYear()} {site.name}</span>
      <ThemeToggle />
    </div>
  </div>
</aside>

<script>
  // 滚动监听：高亮当前章节对应的导航项
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.sp-nav-link'));
  const byId = new Map(links.map((l) => [l.dataset.nav, l]));
  const sections = siteNavIds();

  function siteNavIds(): string[] {
    return Array.from(document.querySelectorAll<HTMLElement>('.sp-nav-link')).map(
      (l) => l.dataset.nav || ''
    );
  }

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const id = (e.target as HTMLElement).id;
        links.forEach((l) => l.classList.remove('active'));
        byId.get(id)?.classList.add('active');
      });
    },
    { rootMargin: '-45% 0px -50% 0px' }
  );
  sections.forEach((id) => {
    const el = document.getElementById(id);
    if (el) io.observe(el);
  });
</script>
