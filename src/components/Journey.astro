---
import { journey } from '../data/journey';
---
<section id="journey" class="stream-section">
  <div class="stream-label">
    <span class="sl-line" aria-hidden="true"></span>
    <span class="sl-text">Journey</span>
  </div>
  <p class="stream-lead">一段由代码串起的成长轨迹 — The Path So Far</p>

  <ol class="timeline">
    {
      journey.map((m) => (
        <li class="tl-item reveal">
          <span class="tl-dot" aria-hidden="true"></span>
          <span class="tl-year">{m.year}</span>
          <h2 class="tl-title">{m.title}</h2>
          <p class="tl-desc">{m.desc}</p>
          <span class="tl-tag">{m.tag}</span>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: linear-gradient(var(--border), var(--border-strong));
  }
  .tl-item {
    position: relative;
    padding: 0 0 var(--space-lg) 2.2rem;
  }
  .tl-item:last-child { padding-bottom: 0; }
  .tl-dot {
    position: absolute;
    left: 0;
    top: 4px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg-deep);
    border: 2px solid var(--accent-blue);
    box-sizing: border-box;
  }
  .tl-year {
    font-family: var(--font-mono);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--accent);
  }
  .tl-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0.2rem 0 0.3rem;
  }
  .tl-desc {
    font-size: 0.84rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }
  .tl-tag {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    color: var(--accent-cyan);
    background: var(--accent-soft);
    border: 1px solid var(--border);
  }
</style>
