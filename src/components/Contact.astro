---
import { site } from '../data/site';

const icons: Record<string, string> = {
  web: '<svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="16" r="4.5" stroke="currentColor" stroke-width="1.2"/><line x1="4" y1="16" x2="28" y2="16" stroke="currentColor" stroke-width="0.8" opacity="0.5"/><path d="M16 4a18 18 0 010 24" stroke="currentColor" stroke-width="0.8" opacity="0.5"/></svg>',
  x: '<svg viewBox="0 0 32 32" fill="none"><path d="M6 6l8.8 12L6 28h2l7.7-9 6.3 9H28l-9.3-12.6L25.6 6h-2l-7 8.4L10.4 6H6z" fill="currentColor"/></svg>',
  tg: '<svg viewBox="0 0 32 32" fill="none"><path d="M5 15l8 3.2 3.2 8L26 6 5 15z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>',
  wechat: '<svg viewBox="0 0 32 32" fill="none"><path d="M11 13.5a1.5 1.5 0 110-3 1.5 1.5 0 010 3zM22 13.5a1.5 1.5 0 110-3 1.5 1.5 0 010 3z" fill="currentColor"/><path d="M16 4C9.4 4 4 8.4 4 14c0 3.2 1.8 6 4.6 7.8L7 26l4.8-2.4c1 .3 2 .4 3.2.4 6.6 0 12-4.4 12-10S22.6 4 16 4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M16 4c6.6 0 12 4.4 12 10 0 2.5-1.2 4.8-3.2 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
  qq: '<svg viewBox="0 0 32 32" fill="none"><ellipse cx="16" cy="17" rx="10" ry="8" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="11" r="5" stroke="currentColor" stroke-width="1.5"/><circle cx="13.5" cy="10" r="1" fill="currentColor"/><circle cx="18.5" cy="10" r="1" fill="currentColor"/><path d="M14 13.5a3 3 0 004 0" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>',
  email: '<svg viewBox="0 0 32 32" fill="none"><rect x="4" y="7" width="24" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M4 10l12 9 12-9" stroke="currentColor" stroke-width="1.5"/></svg>',
  github: '<svg viewBox="0 0 32 32" fill="none"><path d="M12 27c-5 1.2-5-2.5-7.5-3m14.5 11v-5.4c0-1.5-.5-2.7-1.3-3.5 4.5-.5 9.3-2.3 9.3-10 0-2.2-.8-4-2-5.5.2-.5.8-2.6-.3-5.3 0 0-1.7-.5-5.5 2a19 19 0 00-10 0c-3.8-2.5-5.5-2-5.5-2-1.1 2.7-.5 4.8-.3 5.3a8 8 0 00-2 5.5c0 7.7 4.8 9.5 9.3 10-.7.8-1.3 2-1.3 3.5V32" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
};
---
<section id="contact" class="section">
  <div class="section-inner">
    <div class="section-label reveal">
      <span class="label-line"></span>
      <span class="label-text">C O N T A C T</span>
      <span class="label-line"></span>
    </div>
    <p class="contact-subtitle reveal">期待与你交流 — Let's Connect</p>
    <div class="contact-grid">
      {
        site.contacts.map((c) => (
          <a
            class="contact-card glass-card reveal"
            class:list={[c.copy ? '' : 'is-link']}
            data-platform={c.platform}
            href={c.copy ? undefined : c.href}
            target={c.copy ? undefined : '_blank'}
            rel={c.copy ? undefined : 'noopener'}
            role={c.copy ? 'button' : undefined}
            tabindex={c.copy ? 0 : undefined}
          >
            <div class="contact-icon" set:html={icons[c.platform]} />
            <span class="contact-name">{c.name}</span>
            <span class="contact-detail">{c.detail}</span>
            {c.copy && <span class="contact-copy-hint">点击复制</span>}
          </a>
        ))
      }
    </div>
  </div>
  <div class="copy-toast" id="copyToast" aria-live="polite"></div>
</section>

<script>
  const copyable = ['wechat', 'qq', 'email'];
  const toast = document.getElementById('copyToast');
  let toastTimer: number | undefined;
  function showToast(msg: string) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('show');
    window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => toast.classList.remove('show'), 1800);
  }

  document.querySelectorAll<HTMLElement>('.contact-card[data-platform]').forEach((card) => {
    const platform = card.dataset.platform || '';
    if (!copyable.includes(platform)) return;
    const detail = card.querySelector('.contact-detail')?.textContent?.trim() || '';
    const doCopy = async () => {
      try {
        await navigator.clipboard.writeText(detail);
        showToast(`已复制：${detail}`);
      } catch {
        showToast('复制失败，请手动复制');
      }
    };
    card.addEventListener('click', doCopy);
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        doCopy();
      }
    });
  });
</script>
