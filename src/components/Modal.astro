---
import modals from '../data/modals.json';
---
<div class="modal-overlay" id="modalOverlay" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <button class="modal-close" id="modalClose" aria-label="关闭">&times;</button>
    <div class="modal-icon" id="modalIcon"></div>
    <h3 class="modal-title" id="modalTitle"></h3>
    <p class="modal-subtitle" id="modalSubtitle"></p>
    <div class="modal-details" id="modalDetails"></div>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1900;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(10, 10, 20, 0.72);
    backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s;
  }
  .modal-overlay.open {
    opacity: 1;
    visibility: visible;
  }
  .modal-card {
    position: relative;
    max-width: 560px;
    width: 100%;
    max-height: 86vh;
    overflow-y: auto;
    padding: 2.4rem 2rem 2rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(24px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    transform: translateY(20px) scale(0.96);
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .modal-overlay.open .modal-card {
    transform: translateY(0) scale(1);
  }
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1.2rem;
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s;
  }
  .modal-close:hover {
    color: var(--text-primary);
  }
  .modal-icon :global(svg) {
    width: 56px;
    height: 56px;
    margin: 0 auto 0.8rem;
    display: block;
  }
  .modal-title {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
    background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple), var(--accent-cyan));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .modal-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-top: 0.3rem;
    margin-bottom: 1.4rem;
  }
  .modal-details {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.8;
  }
  .modal-details :global(h4) {
    color: var(--text-primary);
    font-size: 1.05rem;
    font-weight: 600;
    margin: 1.2rem 0 0.5rem;
  }
  .modal-details :global(h4:first-child) {
    margin-top: 0;
  }
  .modal-details :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0.4rem 0;
  }
  .modal-details :global(li) {
    padding-left: 1.1rem;
    position: relative;
    margin: 0.3rem 0;
  }
  .modal-details :global(li)::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--accent-cyan);
  }
  .modal-details :global(li strong) {
    color: var(--text-primary);
  }
  .modal-details :global(p) {
    margin: 0.6rem 0;
  }
  .modal-details :global(.tech-tag) {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    margin: 0.25rem 0.3rem 0.25rem 0;
    border-radius: 999px;
    font-size: 0.78rem;
    color: var(--accent-cyan);
    background: rgba(34, 211, 238, 0.12);
    border: 1px solid rgba(34, 211, 238, 0.25);
  }
</style>

<script define:vars={{ modals }}>
  const overlay = document.getElementById('modalOverlay');
  const iconEl = document.getElementById('modalIcon');
  const titleEl = document.getElementById('modalTitle');
  const subEl = document.getElementById('modalSubtitle');
  const detEl = document.getElementById('modalDetails');
  const closeBtn = document.getElementById('modalClose');

  let lastFocused: HTMLElement | null = null;

  function getFocusable(): HTMLElement[] {
    if (!overlay) return [];
    return Array.from(
      overlay.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input, [tabindex]:not([tabindex="-1"]), [role="button"]'
      )
    );
  }

  function close() {
    overlay?.classList.remove('open');
    overlay?.setAttribute('aria-hidden', 'true');
    // 焦点归还触发元素
    lastFocused?.focus();
    lastFocused = null;
  }

  function openModal(group: string, key: string) {
    const data = (modals as any)[group]?.[key];
    if (!data || !overlay) return;
    if (iconEl) iconEl.innerHTML = data.icon;
    if (titleEl) titleEl.textContent = data.title;
    if (subEl) subEl.textContent = data.subtitle;
    if (detEl) detEl.innerHTML = data.details;
    lastFocused = document.activeElement as HTMLElement | null;
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    // 打开时把焦点移入对话框
    const f = getFocusable();
    (f[0] ?? overlay).focus();
  }

  window.addEventListener('open-modal', (e: Event) => {
    const { group, key } = (e as CustomEvent).detail;
    openModal(group, key);
  });
  closeBtn?.addEventListener('click', close);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) close();
  });
  // 焦点陷阱：在对话框内循环 Tab
  overlay?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Tab' || !overlay.classList.contains('open')) return;
    const f = getFocusable();
    if (!f.length) return;
    const first = f[0];
    const last = f[f.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('open')) close();
  });
</script>
