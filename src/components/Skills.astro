---
import { skills } from '../data/skills';

const groups = [
  { key: 'lang', label: '编程语言' },
  { key: 'fe', label: '前端' },
  { key: 'be', label: '后端' },
  { key: 'devops', label: '基础设施' },
  { key: 'ai', label: 'AI' },
] as const;

const byCat = (c: string) => skills.filter((s) => s.category === c).map((s) => s.name);
---
<section id="skills" class="stream-section">
  <div class="stream-label">
    <span class="sl-line" aria-hidden="true"></span>
    <span class="sl-text">Skills</span>
  </div>
  <div class="skill-groups">
    {
      groups.map((g) => (
        <div class="skill-group reveal">
          <span class="skill-group-label">{g.label}</span>
          <div class="skill-tags">
            {byCat(g.key).map((n) => (
              <span class="skill-tag">{n}</span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .skill-group {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }
  .skill-group-label {
    flex-shrink: 0;
    width: 5.5rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    padding-top: 0.35rem;
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .skill-tag {
    font-size: 0.84rem;
    color: var(--text-secondary);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    padding: 0.32rem 0.75rem;
    border-radius: 8px;
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .skill-tag:hover {
    color: var(--accent);
    border-color: var(--accent-soft);
    transform: translateY(-1px);
  }
  @media (max-width: 560px) {
    .skill-group { flex-direction: column; gap: 0.5rem; }
    .skill-group-label { width: auto; padding-top: 0; }
  }
</style>
