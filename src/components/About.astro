---
const base = import.meta.env.BASE_URL;
---
<section id="about" class="section">
  <div class="section-inner">
    <div class="section-label reveal">
      <span class="label-line"></span>
      <span class="label-text">A B O U T</span>
      <span class="label-line"></span>
    </div>
    <div class="about-grid">
      <!-- 卡片1：何以为我 — 独占上行全宽 -->
      <div class="about-card about-card-hero glass-card reveal">
        <span class="card-number">01</span>
        <div class="about-hero-layout">
          <div class="hero-slideshow" role="region" aria-roledescription="carousel" aria-label="个人介绍轮播">
            <div class="hero-slideshow-track">
              <!-- Slide 1 -->
              <div class="hero-slide" role="group" aria-label="第1张，共3张">
                <div class="hero-slide-text">
                  <div class="hero-header-row">
                    <svg class="hero-eyebrow-icon" viewBox="0 0 120 100" width="96" height="80" fill="none" aria-hidden="true">
                      <rect x="20" y="12" width="80" height="54" rx="5" stroke="currentColor" stroke-width="2" fill="none" opacity="0.9" />
                      <rect x="28" y="20" width="64" height="38" rx="2" fill="currentColor" opacity="0.15" />
                      <rect x="34" y="26" width="20" height="2.5" rx="1.2" fill="currentColor" opacity="0.5" />
                      <rect x="34" y="32" width="36" height="2.5" rx="1.2" fill="currentColor" opacity="0.7" />
                      <rect x="34" y="38" width="14" height="2.5" rx="1.2" fill="var(--accent-blue)" opacity="0.8" />
                      <rect x="34" y="44" width="28" height="2.5" rx="1.2" fill="currentColor" opacity="0.5" />
                      <rect x="34" y="50" width="10" height="2.5" rx="1.2" fill="var(--accent-purple)" opacity="0.8" />
                      <line x1="60" y1="66" x2="60" y2="76" stroke="currentColor" stroke-width="2" opacity="0.6" />
                      <line x1="42" y1="76" x2="78" y2="76" stroke="currentColor" stroke-width="2" opacity="0.6" stroke-linecap="round" />
                      <rect x="30" y="80" width="60" height="10" rx="3" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.5" />
                      <line x1="36" y1="85" x2="84" y2="85" stroke="currentColor" stroke-width="1" opacity="0.3" />
                      <rect x="94" y="64" width="14" height="11" rx="2" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.5" />
                      <path d="M108 67 Q112 67 112 70.5 Q112 74 108 74" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.5" />
                      <line x1="100" y1="62" x2="102" y2="58" stroke="currentColor" stroke-width="1" opacity="0.3" stroke-linecap="round" />
                    </svg>
                    <div class="hero-title-block">
                      <span class="hero-eyebrow">Know Thyself</span>
                      <h3 class="card-title hero-main-title">何以为我</h3>
                      <strong class="hero-name-large">Valkjin</strong>
                    </div>
                  </div>
                  <p class="card-desc hero-desc">
                    <span class="hero-role">Full-Stack Engineer &amp; Indie Developer</span>
                    <span class="hero-tagline">AI 驱动产品与自动化，构建有序的数字世界。</span>
                  </p>
                </div>
                <div class="hero-slide-image image-reveal">
                  <div class="gallery-image-wrapper">
                    <picture>
                      <source srcset={`${base}img/slide1.webp`} type="image/webp" />
                      <img src={`${base}img/slide1.png`} alt="Avatar" loading="lazy" onerror="this.style.display='none';this.closest('.gallery-image-wrapper').classList.add('gallery-fallback')" />
                    </picture>
                    <div class="gallery-fallback-content">
                      <svg viewBox="0 0 48 48" fill="none"><rect x="6" y="8" width="36" height="32" rx="4" stroke="currentColor" stroke-width="1.5" /><circle cx="17" cy="19" r="4" stroke="currentColor" stroke-width="1.2" /><path d="M6 32l10-10 8 8 6-6 12 12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" /></svg>
                      <span>Photo</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Slide 2 -->
              <div class="hero-slide" role="group" aria-label="第2张，共3张">
                <div class="hero-slide-text">
                  <div class="hero-header-row">
                    <div class="card-illustration">
                      <svg viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="60" cy="45" r="28" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.4" />
                        <circle cx="60" cy="45" r="18" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.6" />
                        <circle cx="60" cy="45" r="8" fill="var(--accent-blue)" opacity="0.5" />
                        <circle cx="42" cy="32" r="4" fill="var(--accent-cyan)" opacity="0.7" />
                        <circle cx="78" cy="35" r="3.5" fill="var(--accent-purple)" opacity="0.6" />
                        <circle cx="52" cy="62" r="3" fill="var(--accent-blue)" opacity="0.5" />
                        <circle cx="72" cy="58" r="4" fill="var(--accent-cyan)" opacity="0.6" />
                        <line x1="42" y1="32" x2="55" y2="42" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                        <line x1="78" y1="35" x2="65" y2="43" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                        <line x1="55" y1="48" x2="52" y2="62" stroke="currentColor" stroke-width="0.8" opacity="0.2" />
                        <line x1="65" y1="48" x2="72" y2="58" stroke="currentColor" stroke-width="0.8" opacity="0.2" />
                        <rect x="28" y="76" width="64" height="8" rx="3" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.4" />
                        <rect x="32" y="78" width="24" height="4" rx="2" fill="var(--accent-blue)" opacity="0.6" />
                      </svg>
                    </div>
                    <div class="hero-title-block">
                      <span class="hero-eyebrow">Into the Unknown</span>
                      <h3 class="card-title">向何而去</h3>
                      <strong class="hero-name-large">Pathfinder</strong>
                    </div>
                  </div>
                  <p class="card-desc hero-desc">
                    <span class="hero-role">AI Explorer &amp; System Architect</span>
                    <span class="hero-tagline">穿越技术迷雾，于未知中探寻方向与答案。</span>
                  </p>
                  <div class="about-hero-details">
                    <div class="hero-detail-item">
                      <span class="detail-icon"><svg viewBox="0 0 20 20" fill="none"><path d="M9.5 2.5L4.5 7l1.2 1.2 3.8-3.8 5 5L15.5 8l-6-5.5z" fill="currentColor" opacity="0.3" /><rect x="4" y="8" width="12" height="9" rx="2" stroke="currentColor" stroke-width="1.4" fill="none" /><path d="M7 11.5h6M7 14h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" /></svg></span>
                      <span class="detail-label">LLM 应用架构</span>
                      <span class="detail-tag">智能体工作流</span>
                    </div>
                    <div class="hero-detail-item">
                      <span class="detail-icon"><svg viewBox="0 0 20 20" fill="none"><rect x="3" y="2" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none" /><rect x="10" y="9" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none" /><circle cx="6.5" cy="5.5" r="1.5" fill="currentColor" opacity="0.5" /><circle cx="13.5" cy="12.5" r="1.5" fill="currentColor" opacity="0.5" /><path d="M9 6.5h3M9 12.5h3M11.5 5v3M11.5 11v3" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3" /></svg></span>
                      <span class="detail-label">端侧 AI 推理</span>
                      <span class="detail-tag">优化与部署</span>
                    </div>
                  </div>
                </div>
                <div class="hero-slide-image image-float">
                  <div class="gallery-image-wrapper">
                    <picture>
                      <source srcset={`${base}img/slide2.webp`} type="image/webp" />
                      <img src={`${base}img/slide2.png`} alt="Screenshot" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('gallery-fallback')" />
                    </picture>
                    <div class="gallery-fallback-content">
                      <svg viewBox="0 0 48 48" fill="none"><rect x="6" y="8" width="36" height="32" rx="4" stroke="currentColor" stroke-width="1.5" /><circle cx="17" cy="19" r="4" stroke="currentColor" stroke-width="1.2" /><path d="M6 32l10-10 8 8 6-6 12 12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" /></svg>
                      <span>Screenshot</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Slide 3 -->
              <div class="hero-slide" role="group" aria-label="第3张，共3张">
                <div class="hero-slide-text">
                  <div class="hero-header-row">
                    <div class="card-illustration">
                      <svg viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="24" y="18" width="72" height="64" rx="6" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.5" />
                        <rect x="30" y="26" width="60" height="6" rx="2" fill="var(--accent-blue)" opacity="0.4" />
                        <rect x="30" y="37" width="42" height="4" rx="1.5" fill="currentColor" opacity="0.3" />
                        <rect x="30" y="46" width="50" height="4" rx="1.5" fill="currentColor" opacity="0.25" />
                        <rect x="30" y="55" width="36" height="4" rx="1.5" fill="var(--accent-purple)" opacity="0.35" />
                        <rect x="30" y="64" width="28" height="4" rx="1.5" fill="currentColor" opacity="0.2" />
                        <rect x="38" y="78" width="44" height="3" rx="1.5" fill="var(--accent-cyan)" opacity="0.3" />
                      </svg>
                    </div>
                    <div class="hero-title-block">
                      <span class="hero-eyebrow">The Making</span>
                      <h3 class="card-title">何以筑之</h3>
                      <strong class="hero-name-large">The Architect</strong>
                    </div>
                  </div>
                  <p class="card-desc hero-desc">
                    <span class="hero-role">Tooling Engineer &amp; Systems Architect</span>
                    <span class="hero-tagline">从底层基建到上层应用，精心构筑数字世界的每一块基石。</span>
                  </p>
                  <div class="about-hero-details">
                    <div class="hero-detail-item">
                      <span class="detail-icon"><svg viewBox="0 0 20 20" fill="none"><path d="M3 5h14l-1.5 10H4.5L3 5z" stroke="currentColor" stroke-width="1.4" fill="none" /><path d="M7 5V3a1 1 0 011-1h4a1 1 0 011 1v2" stroke="currentColor" stroke-width="1.2" fill="none" /><rect x="7.5" y="8" width="5" height="1.5" rx="0.5" fill="currentColor" opacity="0.5" /><rect x="7.5" y="11" width="3.5" height="1.5" rx="0.5" fill="currentColor" opacity="0.4" /></svg></span>
                      <span class="detail-label">开发者工具链</span>
                      <span class="detail-tag">自动化效率</span>
                    </div>
                    <div class="hero-detail-item">
                      <span class="detail-icon"><svg viewBox="0 0 20 20" fill="none"><circle cx="10" cy="6" r="3" stroke="currentColor" stroke-width="1.4" fill="none" /><path d="M4 17c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.4" fill="none" /><circle cx="6" cy="12" r="1" fill="currentColor" opacity="0.35" /><circle cx="14" cy="11" r="0.8" fill="currentColor" opacity="0.35" /><circle cx="10" cy="10" r="0.7" fill="currentColor" opacity="0.3" /></svg></span>
                      <span class="detail-label">开源社区贡献</span>
                      <span class="detail-tag">技术分享</span>
                    </div>
                  </div>
                </div>
                <div class="hero-slide-image image-mosaic">
                  <div class="gallery-image-wrapper">
                    <picture>
                      <source srcset={`${base}img/slide3.webp`} type="image/webp" />
                      <img src={`${base}img/slide3.png`} alt="Project" loading="lazy" onerror="this.style.display='none';this.closest('.gallery-image-wrapper').classList.add('gallery-fallback')" />
                    </picture>
                    <div class="gallery-fallback-content">
                      <svg viewBox="0 0 48 48" fill="none"><rect x="6" y="8" width="36" height="32" rx="4" stroke="currentColor" stroke-width="1.5" /><circle cx="17" cy="19" r="4" stroke="currentColor" stroke-width="1.2" /><path d="M6 32l10-10 8 8 6-6 12 12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" /></svg>
                      <span>Project</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="carousel-dots" aria-label="轮播控制">
              <button type="button" class="carousel-prev" aria-label="上一张">
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </button>
              <button type="button" class="carousel-pause-btn" aria-label="暂停轮播" aria-pressed="false">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <g class="pause-icon"><rect x="7" y="6" width="3" height="12" rx="1" /><rect x="14" y="6" width="3" height="12" rx="1" /></g>
                  <path class="play-icon" d="M9 6l10 6l-10 6z" style="display:none" />
                </svg>
              </button>
              <span class="carousel-dots-inner"></span>
              <button type="button" class="carousel-next" aria-label="下一张">
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M8 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </button>
            </div>
          </div>
        </div>

        <!-- 下方 3 列子网格 -->
        <div class="about-grid-sub">
          <!-- 卡片2：探索方向 -->
          <div class="about-card glass-card reveal explore-card">
            <span class="card-number">02</span>
            <div class="card-illustration">
              <svg viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="30" cy="20" r="5" fill="var(--accent-blue)" opacity="0.8" />
                <circle cx="60" cy="12" r="4.5" fill="var(--accent-purple)" opacity="0.7" />
                <circle cx="90" cy="20" r="5" fill="var(--accent-blue)" opacity="0.8" />
                <circle cx="20" cy="50" r="4.5" fill="var(--accent-purple)" opacity="0.7" />
                <circle cx="45" cy="42" r="5.5" fill="var(--accent-blue)" opacity="0.9" />
                <circle cx="75" cy="42" r="5.5" fill="var(--accent-purple)" opacity="0.9" />
                <circle cx="100" cy="50" r="4.5" fill="var(--accent-blue)" opacity="0.7" />
                <circle cx="30" cy="72" r="5" fill="var(--accent-purple)" opacity="0.8" />
                <circle cx="60" cy="80" r="4.5" fill="var(--accent-blue)" opacity="0.7" />
                <circle cx="90" cy="72" r="5" fill="var(--accent-purple)" opacity="0.8" />
                <line x1="30" y1="20" x2="60" y2="12" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                <line x1="60" y1="12" x2="90" y2="20" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                <line x1="30" y1="20" x2="20" y2="50" stroke="currentColor" stroke-width="0.8" opacity="0.2" />
                <line x1="30" y1="20" x2="45" y2="42" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
                <line x1="60" y1="12" x2="45" y2="42" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                <line x1="60" y1="12" x2="75" y2="42" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                <line x1="90" y1="20" x2="75" y2="42" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
                <line x1="90" y1="20" x2="100" y2="50" stroke="currentColor" stroke-width="0.8" opacity="0.2" />
                <line x1="20" y1="50" x2="45" y2="42" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
                <line x1="45" y1="42" x2="75" y2="42" stroke="currentColor" stroke-width="0.8" opacity="0.35" />
                <line x1="75" y1="42" x2="100" y2="50" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
                <line x1="20" y1="50" x2="30" y2="72" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                <line x1="45" y1="42" x2="30" y2="72" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                <line x1="45" y1="42" x2="60" y2="80" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
                <line x1="75" y1="42" x2="60" y2="80" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
                <line x1="75" y1="42" x2="90" y2="72" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                <line x1="100" y1="50" x2="90" y2="72" stroke="currentColor" stroke-width="0.8" opacity="0.25" />
                <line x1="30" y1="72" x2="60" y2="80" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
                <line x1="60" y1="80" x2="90" y2="72" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
                <circle cx="60" cy="42" r="12" stroke="var(--accent-cyan)" stroke-width="1" fill="none" opacity="0.3">
                  <animate attributeName="r" values="12;18;12" dur="3s" repeatCount="indefinite" />
                  <animate attributeName="opacity" values="0.3;0.05;0.3" dur="3s" repeatCount="indefinite" />
                </circle>
              </svg>
            </div>
            <h3 class="card-title">探索方向<br /><span class="card-subtitle">Exploration</span></h3>
            <div class="card-bg-particles" aria-hidden="true">
              <span class="p-dot a1" style="top:12%;left:8%;"></span>
              <span class="p-dot a2" style="top:28%;left:82%;"></span>
              <span class="p-dot a3" style="top:55%;left:12%;"></span>
              <span class="p-dot a4" style="top:75%;left:72%;"></span>
            </div>
            <div class="card-content-row">
              <div class="card-content-text">
                <div class="explore-chips">
                  <span class="explore-chip chip-llm" data-explore="multimodal" role="button" tabindex="0" aria-expanded="false" aria-label="查看多模态感知详情">多模态感知</span>
                  <span class="explore-chip chip-agent" data-explore="reasoning" role="button" tabindex="0" aria-expanded="false" aria-label="查看知识推理详情">知识推理</span>
                  <span class="explore-chip chip-edge" data-explore="explainability" role="button" tabindex="0" aria-expanded="false" aria-label="查看模型可解释性详情">模型可解释性</span>
                </div>
                <p class="explore-extra">
                  从语义理解到多模态对齐，从知识蒸馏到自动化评测体系 —<br />
                  探索 AI 在真实场景中的每一种纵深可能。
                </p>
              </div>
              <figure class="card-content-visual">
                <span class="visual-corner corner-tl" aria-hidden="true"></span>
                <span class="visual-corner corner-tr" aria-hidden="true"></span>
                <span class="visual-corner corner-bl" aria-hidden="true"></span>
                <span class="visual-corner corner-br" aria-hidden="true"></span>
                <picture>
                  <source srcset={`${base}img/02.webp`} type="image/webp" />
                  <img class="card-preview-img" src={`${base}img/02.jpg`} alt="AI 神经网络探索可视化" loading="lazy" decoding="async" />
                </picture>
              </figure>
            </div>
            <div class="card-quote-footer">
              <p class="fold-quote">「万物静观皆自得」</p>
              <p class="fold-quote-ref">— 程颢《秋日偶成》</p>
            </div>
          </div>

          <!-- 卡片3：创造与分享 -->
          <div class="about-card glass-card reveal create-card">
            <span class="card-number">03</span>
            <div class="card-illustration">
              <svg viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M60 12 L52 52 L50 70 L60 78 L70 70 L68 52 Z" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.7" />
                <circle cx="60" cy="38" r="5" fill="var(--bg-deep)" stroke="var(--accent-cyan)" stroke-width="1.5" opacity="0.8" />
                <path d="M54 74 L48 88 L60 78 L72 88 L66 74" fill="var(--accent-blue)" opacity="0.3" class="flame-outer">
                  <animate attributeName="opacity" values="0.3;0.15;0.3" dur="1.5s" repeatCount="indefinite" />
                </path>
                <path d="M57 76 L52 84 L60 78 L68 84 L63 76" fill="var(--accent-purple)" opacity="0.2" class="flame-inner">
                  <animate attributeName="opacity" values="0.2;0.08;0.2" dur="1.5s" repeatCount="indefinite" />
                </path>
                <path d="M52 52 L38 58 L50 60" fill="var(--accent-blue)" opacity="0.2" stroke="currentColor" stroke-width="1" stroke-opacity="0.4" />
                <path d="M68 52 L82 58 L70 60" fill="var(--accent-blue)" opacity="0.2" stroke="currentColor" stroke-width="1" stroke-opacity="0.4" />
                <circle cx="22" cy="16" r="1.5" fill="currentColor" opacity="0.4"><animate attributeName="opacity" values="0.4;0.1;0.4" dur="2s" repeatCount="indefinite" /></circle>
                <circle cx="98" cy="28" r="1.5" fill="currentColor" opacity="0.3"><animate attributeName="opacity" values="0.3;0.08;0.3" dur="2.5s" repeatCount="indefinite" /></circle>
                <circle cx="14" cy="52" r="1.2" fill="currentColor" opacity="0.25"><animate attributeName="opacity" values="0.25;0.06;0.25" dur="3s" repeatCount="indefinite" /></circle>
                <circle cx="104" cy="62" r="1.2" fill="currentColor" opacity="0.3"><animate attributeName="opacity" values="0.3;0.08;0.3" dur="2.8s" repeatCount="indefinite" /></circle>
                <line x1="60" y1="88" x2="60" y2="95" stroke="currentColor" stroke-width="1" opacity="0.2" stroke-dasharray="3 4">
                  <animate attributeName="stroke-dashoffset" values="0;14" dur="1s" repeatCount="indefinite" />
                </line>
              </svg>
            </div>
            <h3 class="card-title">创造与分享<br /><span class="card-subtitle">Create &amp; Share</span></h3>
