<script>
  // 轮播
  const track = document.querySelector<HTMLElement>('.hero-slideshow-track');
  const slides = Array.from(track?.querySelectorAll('.hero-slide') ?? []);
  const dotsInner = document.querySelector<HTMLElement>('.carousel-dots-inner');
  const prev = document.querySelector('.carousel-prev');
  const next = document.querySelector('.carousel-next');
  const pauseBtn = document.querySelector<HTMLButtonElement>('.carousel-pause-btn');
  let current = 0;
  let timer: number | undefined;

  slides.forEach((_, i) => {
    const d = document.createElement('button');
    d.className = 'carousel-dot';
    d.setAttribute('aria-label', `第${i + 1}张`);
    d.addEventListener('click', () => {
      go(i);
      start();
    });
    dotsInner?.appendChild(d);
  });
  const dots = Array.from(dotsInner?.querySelectorAll('.carousel-dot') ?? []);

  function go(i: number) {
    if (!track) return;
    current = (i + slides.length) % slides.length;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, idx) => d.classList.toggle('active', idx === current));
  }
  function start() {
    stop();
    timer = window.setInterval(() => go(current + 1), current === 0 ? 7000 : 6500);
  }
  function stop() {
    if (timer) clearInterval(timer);
  }

  prev?.addEventListener('click', () => {
    go(current - 1);
    start();
  });
  next?.addEventListener('click', () => {
    go(current + 1);
    start();
  });
  pauseBtn?.addEventListener('click', () => {
    const paused = pauseBtn.getAttribute('aria-pressed') === 'true';
    if (paused) {
      pauseBtn.setAttribute('aria-pressed', 'false');
      pauseBtn.querySelector('.pause-icon')?.setAttribute('style', '');
      pauseBtn.querySelector('.play-icon')?.setAttribute('style', 'display:none');
      start();
    } else {
      pauseBtn.setAttribute('aria-pressed', 'true');
      pauseBtn.querySelector('.pause-icon')?.setAttribute('style', 'display:none');
      pauseBtn.querySelector('.play-icon')?.setAttribute('style', '');
      stop();
    }
  });

  // chips → 打开 Modal（事件由 Modal 组件监听）
  function bindChips(attr: string, group: string) {
    document.querySelectorAll(`[${attr}]`).forEach((el) => {
      const open = () => {
        const key = el.getAttribute(attr) || '';
        window.dispatchEvent(new CustomEvent('open-modal', { detail: { group, key } }));
      };
      el.addEventListener('click', open);
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          open();
        }
      });
    });
  }
  bindChips('data-explore', 'explore');
  bindChips('data-create', 'create');
  bindChips('data-tech', 'techStack');

  start();
</script>
