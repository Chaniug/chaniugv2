---
const lead = '我是 Chaniug，一个把重复劳动交给脚本的开发者。';
const paras = [
  '日常以 Python 与 TypeScript 为主，维护 FilterFusion（广告过滤规则管理）、AdSuper（过滤列表自动生成）、IPTV-Collector（中文 IPTV 源聚合）等开源工具，并持续打磨一个支持多模型（x-auto / x-dsv4f / x-glm5.2 等）的 Buddy 客户端。',
  '相信好的工具应当安静、可靠、可维护 —— 把复杂留在底层，把简单交给使用者。代码之外，也喜欢在自动化与流媒体工程的交界处寻找新的可能性。',
];
---
<section id="about" class="stream-section">
  <div class="stream-label">
    <span class="sl-line" aria-hidden="true"></span>
    <span class="sl-text">About</span>
  </div>
  <p class="about-lead reveal">{lead}</p>
  {
    paras.map((p) => (
      <p class="about-body reveal">{p}</p>
    ))
  }
</section>

<style>
  .about-lead {
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 500;
    line-height: 1.45;
    color: var(--text-primary);
    margin: 0 0 var(--space-lg);
    letter-spacing: 0.01em;
  }
  .about-body {
    font-size: 0.95rem;
    line-height: 1.85;
    color: var(--text-secondary);
    margin: 0 0 var(--space-md);
    max-width: 60ch;
  }
  .about-body:last-child { margin-bottom: 0; }
</style>
