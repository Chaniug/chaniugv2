---
import { site } from '../data/site';
import { getGitHubData } from '../data/github';
import { donutChart, barList, statTiles, langColor } from '../lib/charts';

const gh = await getGitHubData();

const counters = [
  {
    target: site.stats.commits,
    suffix: '',
    label: 'Total Commits',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>',
  },
  {
    target: gh.totalStars || site.stats.stars,
    suffix: '',
    label: 'Stars Earned',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
  },
  {
    target: gh.totalRepos || site.stats.repos,
    suffix: '',
    label: 'Repositories',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>',
  },
  {
    target: site.stats.years,
    suffix: '+',
    label: 'Years Coding',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  },
];

// 语言分布环形图（真实数据 top6）
const langEntries = Object.entries(gh.langBytes).sort((a, b) => b[1] - a[1]).slice(0, 6);
const donut = donutChart(
  langEntries.map(([name, bytes]) => ({ label: name, value: bytes, color: langColor(name) })),
  { centerTitle: 'LANG', centerValue: gh.topLanguage }
);
const langLegend = langEntries
  .map(
    ([name, bytes]) =>
      `<span class="lang-legend-item"><i style="background:${langColor(name)}"></i>${name} ${((bytes / (langEntries.reduce((s, [, b]) => s + b, 0) || 1)) * 100).toFixed(0)}%</span>`
  )
  .join('');

// 星标排行 Top（真实仓库）
const topRepos = gh.repos.slice(0, 6);
const starBars = barList(
  topRepos.map((r) => ({ label: r.name, value: r.stars, color: langColor(r.language || '') })),
  { unit: '★' }
);

// 概览瓷砖
const tiles = statTiles([
  { label: 'Repositories', value: String(gh.totalRepos || site.stats.repos) },
  { label: 'Total Stars', value: String(gh.totalStars || site.stats.stars) },
  { label: 'Top Language', value: gh.topLanguage },
  { label: 'Years Coding', value: `${site.stats.years}+` },
]);

const dataNote = gh.fallback ? '（静态回退数据）' : '（实时 GitHub 数据）';
---
<section id="stats" class="stream-section">
  <div class="stream-label">
    <span class="sl-line" aria-hidden="true"></span>
    <span class="sl-text">Statistics</span>
  </div>

  <div class="stats-counters" id="statsCounters">
    {
      counters.map((c) => (
        <div class="stat-counter-card glass-card reveal">
          <div class="counter-icon" set:html={c.icon} />
          <span class="counter-number" data-target={c.target} data-suffix={c.suffix}>0</span>
          <span class="counter-label">{c.label}</span>
        </div>
      ))
    }
  </div>

  <div class="stats-motto reveal">
    <span class="stats-motto-cn">履霜，坚冰至</span>
    <span class="stats-motto-sep">—</span>
    <span class="stats-motto-en">Dripping water hollows out stone.</span>
  </div>

  <div class="stats-charts">
    <div class="stat-card glass-card reveal stat-card-chart">
      <div class="stat-card-accent accent-lang"></div>
      <p class="stat-label">
        <svg class="stat-label-icon" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2" /><circle cx="8" cy="5" r="2.5" fill="currentColor" opacity="0.3" /><circle cx="8" cy="11" r="1.2" fill="currentColor" opacity="0.6" /></svg>
        语言分布
      </p>
      <div class="chart-donut" set:html={donut} />
      <div class="lang-legend" set:html={langLegend} />
    </div>

    <div class="stat-card glass-card reveal stat-card-chart">
      <div class="stat-card-accent accent-commit"></div>
      <p class="stat-label">
        <svg class="stat-label-icon" viewBox="0 0 16 16" fill="none"><polygon points="8,1 10,5.5 15,6 11,9.5 12,14.5 8,12 4,14.5 5,9.5 1,6 6,5.5" stroke="currentColor" stroke-width="1" fill="none" /><circle cx="8" cy="8" r="1.5" fill="currentColor" opacity="0.5" /></svg>
        星标排行
      </p>
      <div class="chart-bars" set:html={starBars} />
    </div>
  </div>

  <div class="stat-card glass-card reveal stat-card-full">
    <p class="stat-label">
      <svg class="stat-label-icon" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.9" /><rect x="5" y="1" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.6" /><rect x="9" y="1" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.3" /><rect x="13" y="1" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.15" /><rect x="1" y="5" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.7" /><rect x="5" y="5" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.4" /><rect x="9" y="5" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.8" /><rect x="13" y="5" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.2" /><rect x="1" y="9" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.3" /><rect x="5" y="9" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.9" /><rect x="9" y="9" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.5" /><rect x="13" y="9" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.15" /><rect x="1" y="13" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.2" /><rect x="5" y="13" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.7" /></svg>
      仓库概览 <span class="data-note">{dataNote}</span>
    </p>
    <div class="gh-tiles" set:html={tiles} />
  </div>
</section>

<style>
  .data-note {
    font-size: 0.62rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    opacity: 0.7;
  }
  .stats-counters {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .stat-counter-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: var(--space-md);
    border-radius: 12px;
    background: var(--glass-bg);
    border: 1px solid var(--border);
    transition: border-color var(--transition-smooth), transform var(--transition-smooth);
  }
  .stat-counter-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .counter-icon { width: 20px; height: 20px; color: var(--accent); opacity: 0.8; }
  .counter-icon :global(svg) { width: 20px; height: 20px; }
  .counter-number {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1;
  }
  .counter-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  .stats-motto {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: var(--space-md) 0 var(--space-lg);
    opacity: 0.8;
  }
  .stats-charts {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }
  .stat-card {
    position: relative;
    padding: var(--space-lg);
    border-radius: 14px;
    background: var(--glass-bg);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .stat-card-accent {
    position: absolute;
    top: 0;
    left: var(--space-lg);
    width: 28px;
    height: 3px;
    border-radius: 0 0 3px 3px;
  }
  .accent-lang { background: var(--accent-blue); }
  .accent-commit { background: var(--accent-cyan); }
  .stat-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin: 0 0 var(--space-sm);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
  .stat-label-icon { width: 14px; height: 14px; opacity: 0.7; }
  .chart-donut { display: flex; justify-content: center; padding: 0.4rem 0; }
  .chart-donut :global(svg) { max-width: 200px; }
  .lang-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    justify-content: center;
    font-size: 0.7rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }
  .lang-legend-item { display: inline-flex; align-items: center; gap: 0.35rem; }
  .lang-legend-item i { width: 9px; height: 9px; border-radius: 2px; display: inline-block; }
  .chart-bars { width: 100%; padding: 0.4rem 0; }
  .gh-tiles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    padding: 0.5rem 0.2rem 0.2rem;
  }
  .gh-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: var(--space-md);
    border-radius: 12px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
  }
  .gh-tile-v {
    font-size: 1.3rem;
    font-weight: 500;
    font-family: var(--font-display);
    color: var(--text-primary);
  }
  .gh-tile-l { font-size: 0.66rem; color: var(--text-muted); letter-spacing: 0.04em; }
  @media (max-width: 560px) {
    .gh-tiles { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  const counters = document.querySelectorAll<HTMLElement>('.counter-number');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const target = Number(el.dataset.target);
        const suffix = el.dataset.suffix || '';
        const dur = 1500;
        const start = performance.now();
        function step(now: number) {
          const p = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
        io.unobserve(el);
      });
    },
    { threshold: 0.5 }
  );
  counters.forEach((c) => io.observe(c));
</script>
