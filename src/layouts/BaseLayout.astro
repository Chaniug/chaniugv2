---
import '../../css/modules/variables.css';
import '../../css/modules/reset.css';
import '../../css/modules/animations.css';
import '../../css/modules/layout.css';
import '../../css/modules/navigation.css';
import '../../css/modules/hero.css';
import '../../css/modules/signature.css';
import '../../css/modules/about.css';
import '../../css/modules/tech-stack.css';
import '../../css/modules/explore.css';
import '../../css/modules/modal.css';
import '../../css/modules/stats.css';
import '../../css/modules/contact.css';
import '../../css/modules/horizontal.css';
import '../../css/modules/responsive.css';

import BackgroundField from '../components/BackgroundField.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Reveal from '../components/Reveal.astro';
import Interactions from '../components/Interactions.astro';
import RailNav from '../components/RailNav.astro';
import ScrollNarrative from '../components/ScrollNarrative.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Valkjin · 探索未来的开发者',
  description = '热爱前沿技术的开发者，专注于 AI、前端、自动化与创意项目。用代码点亮数字世界。',
} = Astro.props;

const ogImage = `${Astro.site}/img/avatar.jpg`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="preconnect" href="https://cdn.simpleicons.org" crossorigin />
    <link rel="preconnect" href="https://github-profile-summary-cards.vercel.app" crossorigin />
    <link rel="preconnect" href="https://raw.githubusercontent.com" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a14" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}img/avatar.webp`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url.href} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0%25' stop-color='%234f8cff'/><stop offset='100%25' stop-color='%23a855f7'/></linearGradient></defs><circle cx='16' cy='16' r='14' fill='%230a0a14' stroke='url(%23g)' stroke-width='1.5'/><path d='M10 22 L16 10 L22 22' stroke='url(%23g)' stroke-width='1.8' fill='none' stroke-linejoin='round'/><circle cx='16' cy='17' r='2' fill='%234f8cff'/></svg>"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />

    <!-- 首屏 critical CSS：消除主样式加载前的 FOUC（白色闪现 / 内容闪现） -->
    <style is:inline>
      :root {
        --bg-deep: #0a0a14;
        --text-primary: rgba(255, 255, 255, 0.92);
        --text-secondary: rgba(255, 255, 255, 0.65);
        --accent-blue: #4f8cff;
        --accent-purple: #a855f7;
        --accent-cyan: #22d3ee;
      }
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        background: #0a0a14;
        color: rgba(255, 255, 255, 0.92);
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .site-nav {
        position: fixed; top: 0; left: 0; right: 0; height: 60px;
        background: rgba(10, 10, 20, 0.12);
        -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
        z-index: 1000;
      }
      .reveal { opacity: 0; }
      .easter-egg-overlay { visibility: hidden; opacity: 0; }
      #tsparticles, #bg-field .orb { position: fixed; }
    </style>
  </head>
  <body>
    <BackgroundField />
    <SiteNav />
    <slot />
    <SiteFooter />
    <Reveal />
    <Interactions />
    <RailNav />
    <ScrollNarrative />
  </body>
</html>
