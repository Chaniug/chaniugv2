---
import '../../css/modules/variables.css';
import '../../css/modules/reset.css';
import '../../css/modules/animations.css';
import '../../css/modules/layout.css';
import '../../css/modules/navigation.css';
import '../../css/modules/hero.css';
import '../../css/modules/signature.css';
import '../../css/modules/about.css';
import '../../css/modules/tech-stack.css';
import '../../css/modules/explore.css';
import '../../css/modules/modal.css';
import '../../css/modules/stats.css';
import '../../css/modules/contact.css';
import '../../css/modules/horizontal.css';
import '../../css/modules/responsive.css';
import '../../css/modules/theme.css';

import BackgroundField from '../components/BackgroundField.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Reveal from '../components/Reveal.astro';
import Interactions from '../components/Interactions.astro';
import RailNav from '../components/RailNav.astro';
import ScrollNarrative from '../components/ScrollNarrative.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Valkjin · 探索未来的开发者',
  description = '热爱前沿技术的开发者，专注于 AI、前端、自动化与创意项目。用代码点亮数字世界。',
} = Astro.props;

const base = import.meta.env.BASE_URL;
// og:image / twitter:image 必须是绝对 URL，且需带上 /chaniugv2/ 子路径
const ogImage = new URL(base + 'img/avatar.jpg', Astro.site).href;

// JSON-LD 结构化数据（Person），提升搜索引擎富媒体结果
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: Astro.url.href,
  image: ogImage,
  description,
  sameAs: [
    'https://github.com/Chaniug',
    'https://x.com/valkjin',
    'https://t.me/valkjin',
  ],
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="robots" content="index, follow" />
    <link rel="preload" as="image" href={`${base}img/avatar.webp`} type="image/webp" />
    <!-- 防主题闪烁：在样式应用前同步设定 data-theme -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (!t) t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f6f3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f0f11" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}img/avatar.webp`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url.href} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0%25' stop-color='%234f8cff'/><stop offset='100%25' stop-color='%23a855f7'/></linearGradient></defs><circle cx='16' cy='16' r='14' fill='%230a0a14' stroke='url(%23g)' stroke-width='1.5'/><path d='M10 22 L16 10 L22 22' stroke='url(%23g)' stroke-width='1.8' fill='none' stroke-linejoin='round'/><circle cx='16' cy='17' r='2' fill='%234f8cff'/></svg>"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@500;700&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />

    <!-- JSON-LD 结构化数据 -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- 首屏 critical CSS：消除主样式加载前的 FOUC（白色闪现 / 内容闪现） -->
    <style is:inline>
      :root {
        --bg-deep: #f7f6f3;
        --text-primary: #16161a;
        --text-secondary: #56565e;
        --accent-blue: #2f5bd0;
        --accent-purple: #6b54b8;
        --accent-cyan: #1f8aa3;
      }
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        background: #f7f6f3;
        color: #16161a;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .site-nav {
        position: fixed; top: 0; left: 0; right: 0; height: 60px;
        background: rgba(247, 246, 243, 0.7);
        -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
        z-index: 1000;
      }
      .reveal { opacity: 0; }
      .easter-egg-overlay { visibility: hidden; opacity: 0; }
      .skip-link {
        position: fixed; top: -100px; left: 12px; z-index: 2000;
        padding: 10px 18px; border-radius: 10px;
        background: var(--accent-blue); color: #fff; font-weight: 600;
        transition: top 0.2s ease;
      }
      .skip-link:focus { top: 12px; outline: 2px solid #fff; }
      main:focus { outline: none; }
    </style>
    <noscript>
      <style>
        /* 无 JS 时，揭示动画不应隐藏内容 */
        .reveal { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>
  </head>
  <body>
    <a href="#main" class="skip-link">跳到主内容</a>
    <BackgroundField />
    <SiteNav />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <Reveal />
    <Interactions />
    <RailNav />
    <ScrollNarrative />
  </body>
</html>
